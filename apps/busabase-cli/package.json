{
  "name": "busabase-cli",
  "version": "0.1.0",
  "description": "Command-line client for the Busabase OpenAPI REST API. Talks to a local or remote `busabase server`.",
  "license": "MIT",
  "homepage": "https://github.com/busabase/busabase/tree/main/apps/busabase-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/busabase/busabase.git",
    "directory": "apps/busabase-cli"
  },
  "bugs": "https://github.com/busabase/busabase/issues",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "busabase-cli": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "prepack": "pnpm run build && node scripts/assert-help.mjs",
    "prepublishOnly": "pnpm run typecheck && pnpm run lint:err && node scripts/assert-help.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome format . --write && biome check .",
    "lint:err": "biome format . --write && biome check . --write --diagnostic-level=error"
  },
  "dependencies": {
    "busabase-sdk": "workspace:*",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
