{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the main Busabase Desktop window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "opener:default",
    "updater:default",
    "allow-busabase-sidecar-control",
    "allow-request-desktop-restart"
  ]
}
