{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Busabase Desktop",
  "version": "0.9.8",
  "identifier": "com.busabase.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3064",
    "beforeBuildCommand": "pnpm prepare:tauri && pnpm build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Busabase Desktop",
        "url": "index.html",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "visible": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 18
        },
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/busabase-server/": "busabase-server/"
    },
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": ["https://s1.busabase.com/public/downloads/busabase-desktop/latest.json"]
    }
  }
}
