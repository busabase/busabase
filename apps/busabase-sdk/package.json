{
  "name": "busabase-sdk",
  "version": "0.9.3",
  "description": "Typed TypeScript/JavaScript SDK for the Busabase OpenAPI REST API. Talks to a local or remote `busabase server` (or Busabase Cloud).",
  "license": "MIT",
  "homepage": "https://github.com/busabase/busabase/tree/main/apps/busabase-sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/busabase/busabase.git",
    "directory": "apps/busabase-sdk"
  },
  "bugs": "https://github.com/busabase/busabase/issues",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run typecheck && pnpm run lint:err && pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome format . --write && biome check .",
    "lint:err": "biome format . --write && biome check . --write --diagnostic-level=error"
  },
  "dependencies": {
    "@orpc/client": "^1.14.6",
    "@orpc/contract": "^1.14.6",
    "@orpc/openapi-client": "^1.14.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "busabase-contract": "workspace:*",
    "open-domains": "workspace:*",
    "openlib": "workspace:*",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=24.18.0"
  }
}
