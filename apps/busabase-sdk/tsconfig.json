{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "declaration": true,
    "types": ["node"],
    "paths": {
      "busabase-contract": ["../../packages/busabase-contract/src/index.ts"],
      "busabase-contract/domains": ["../../packages/busabase-contract/src/domains/registry.ts"],
      "busabase-contract/*": ["../../packages/busabase-contract/src/*"],
      "open-domains/attachments/types": [
        "../../packages/open-domains/attachments/types/attachments.ts"
      ],
      "open-domains/*": ["../../packages/open-domains/*"],
      "openlib/*": ["../../packages/openlib/*"]
    }
  },
  "include": ["src/**/*.ts", "tsup.config.ts"]
}
