PG_DATABASE_URL="pglite://.data/busabase"

# Exact comma-separated origins allowed to embed /dashboard/*/airapp/*.
# Production defaults to https://dev.buda.im and https://buda.im.
# Local development also allows Buda at http://localhost:3040.
# BUSABASE_AIRAPP_EMBED_ORIGINS="https://dev.buda.im,https://buda.im"

# Storage for folder-backed nodes such as SkillNode.
# Local development:
STORAGE_URL="local:.data/busabase-storage?base_url=/api/dev/attachment"

# MinIO / S3-compatible local development:
# STORAGE_URL="minio://minioadmin:minioadmin@127.0.0.1:9000/busabase?ssl=false&auto_create=true"

# Cloudflare R2:
# STORAGE_URL="r2://ACCESS_KEY_ID:SECRET_ACCESS_KEY@ACCOUNT_ID.r2.cloudflarestorage.com/busabase"

# AWS S3:
# STORAGE_URL="s3://ACCESS_KEY_ID:SECRET_ACCESS_KEY@s3.amazonaws.com/busabase?region=us-east-1"
