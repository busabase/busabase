{
  "$schema": "https://biomejs.dev/schemas/2.2.3/schema.json",
  "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 2, "lineWidth": 100 },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noUnknownAtRules": "off",
        "noExplicitAny": "off"
      },
      "correctness": {
        "useUniqueElementIds": "off"
      },
      "complexity": {
        "noImportantStyles": "off"
      },
      "a11y": {
        "useSemanticElements": "off",
        "useKeyWithClickEvents": "off"
      }
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    },
    "enabled": true
  },
  "files": {
    "includes": [
      "**",
      "!boilerplates",
      "!videos",
      "!**/playwright-report",
      "!apps/costory/**/*.js",
      "!**/scripts/cookbook-pdf/book",
      "!**/.react-email",
      "!**/.source",
      "!**/dist",
      "!**/.data",
      "!**/.tmp",
      "!**/.tmp-*",
      "!**/.next",
      "!**/.d.ts",
      "!**/.expo",
      "!**/.clerk",
      "!**/out",
      "!**/plugin_packages",
      "!**/.venv",
      "!**/node_modules",
      "!**/dist",
      "!**/build",
      "!**/coverage",
      "!**/pnpm-lock.yaml",
      "!**/storybook-static",
      "!**/prisma-client",
      "!**/public",
      "!**/i18n/i18n-types.ts",
      "!**/i18n/i18n-util.ts",
      "!**/i18n/i18n-util.async.ts",
      "!**/i18n/i18n-util.sync.ts",
      "!**/i18n/i18n-react.tsx",
      "!**/i18n/formatters.ts"
    ]
  }
}
