{
  "name": "busabase-repo",
  "private": true,
  "version": "0.9.13",
  "packageManager": "pnpm@10.15.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter busabase dev",
    "build": "pnpm --filter busabase build",
    "example:dev": "pnpm --filter busabase-cms-nextjs-example dev",
    "example:build": "pnpm --filter busabase-cms-nextjs-example build",
    "start": "pnpm --filter busabase start",
    "typecheck": "pnpm --filter busabase typecheck",
    "lint": "pnpm --filter busabase lint:err",
    "test": "pnpm --filter busabase test",
    "db:generate": "pnpm --filter busabase db:generate",
    "db:migrate": "pnpm --filter busabase db:migrate",
    "db:seed": "pnpm --filter busabase db:seed"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.3",
    "tsx": "^4.20.5"
  },
  "pnpm": {
    "patchedDependencies": {
      "@react-native-cookies/cookies@6.2.1": "patches/@react-native-cookies__cookies@6.2.1.patch",
      "@scelar/nodepod@1.9.9": "patches/@scelar__nodepod@1.9.9.patch"
    }
  }
}
