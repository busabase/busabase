# Busabase Cloud or self-hosted server root (do not include /api/v1).
BUSABASE_BASE_URL=https://busabase.com
BUSABASE_API_KEY=bb_your_api_key
BUSABASE_SPACE_ID=your_space_id

# Folder that owns Posts, Pages, Categories, and Tags. The example lazily creates
# missing Bases/fields and stores their stable Base IDs in the Folder metadata.
BUSABASE_CMS_FOLDER_ID=your_folder_node_id

# Optional: absolute URL used by sitemap.xml and canonical metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
