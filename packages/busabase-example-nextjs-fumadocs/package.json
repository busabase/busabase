    "prebuild": "pnpm --filter busabase-sdk build && pnpm --filter busabase-cms build",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "busabase-cms": "workspace:*",
    "busabase-sdk": "workspace:*",
