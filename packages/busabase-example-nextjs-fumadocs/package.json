{
  "name": "busabase-example-nextjs-fumadocs",
  "version": "0.1.0",
  "private": true,
  "description": "Runnable Next.js and Fumadocs example for the four-Base Busabase CMS.",
  "scripts": {
    "predev": "pnpm --filter busabase-sdk build && pnpm --filter busabase-cms build",
