    "fumadocs-ui": "16.7.7",
    "lucide-react": "^0.556.0",
    "next": "16.2.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.18.0"
  }
}
