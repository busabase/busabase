+  // 1.5. [busabase patch] reserved API bridge prefix — never claimed by a
+  //      pod, so it can never collide with an AirApp's own /api/* routes.
+  //      Strips the prefix and replays the request against the real host
+  //      origin with credentials included, so the browser's own (possibly
+  //      httpOnly) session cookie rides along automatically — this is a
+  //      genuine browser-native fetch, never routed through the virtual
+  //      Node process, which has no access to real browser cookies.
+  if (url.pathname.startsWith("/__busabase_api__/")) {
+    const strippedPathAndSearch = url.pathname.slice("/__busabase_api__".length) + url.search;
+    // [busabase patch] `/__busabase_api__/api/airapp-embed-bridge/*` is the
+    // AirApp Embed runtime's OWN safe relay target (airapp-embed-runtime.tsx
+    // — both its postMessage bridge and its `_status` heartbeat fetch this,
+    // always from the trusted PARENT/host page, never from inside a pod).
+    // That endpoint strips `cookie`/`authorization` server-side itself and
+    // is capability-scoped, so it is safe to forward unconditionally
+    // regardless of which pod (if any) is attributed to this request.
+    const isSafeEmbedBridgePath = strippedPathAndSearch.startsWith("/api/airapp-embed-bridge/");
+    if (!isSafeEmbedBridgePath) {
+      // Only forward the browser's real ambient session to pods booted
+      // WITHOUT a preview script — that's the authenticated Dashboard
+      // "preview my own AirApp" path. Any pod that had setPreviewScript()
+      // called on it (currently: only the public AirApp Embed runtime, see
+      // airapp-embed-runtime.tsx) must never get the viewer's real session,
+      // even via a request that bypasses the window.fetch override (e.g.
+      // raw XMLHttpRequest) — fail closed if we can't positively attribute
+      // the request to a non-embed pod.
+      const pod = clientId ? previewClients.get(clientId) : null;
+      if (!pod || previewScripts.has(pod.instanceId)) {
+        event.respondWith(new Response(null, { status: 403 }));
+        return;
+      }
+    }
+    const target = new URL(strippedPathAndSearch, self.location.origin);
+    const bridgeFetch = (async () => {
+      let body;
+      if (request.method !== "GET" && request.method !== "HEAD") {
+        body = await request.clone().arrayBuffer();
+      }
+      return fetch(target.href, {
+        method: request.method,
+        headers: request.headers,
+        body,
+        credentials: "include",
+        redirect: "follow",
+      });
+    })();
+    event.respondWith(bridgeFetch);
+    return;
+  }
